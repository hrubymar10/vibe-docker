#!/bin/bash
# VS Code wrapper for editor integrations.
#
# The extension launches the configured binary as the terminal shell and passes
# prompts via argv (shellArgs). We simply forward everything to vibe-docker so vibe
# runs inside the container instead of on the host.
set -euo pipefail

# Resolve symlinks so SCRIPT_DIR points at the real bin/ directory
# even when invoked via /usr/local/bin/<symlink>.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  link_dir="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$link_dir/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
exec "$SCRIPT_DIR/vibe-docker" "$@"
