#!/bin/bash
# Run Mistral Vibe inside the Docker container in the current working directory.
set -euo pipefail

CONTAINER="${VIBE_DOCKER_CONTAINER:-vibe-docker}"
DOCKER_USER="${VIBE_DOCKER_USER:-$(whoami)}"
WORKDIR="$(pwd)"

# Resolve symlinks so SCRIPT_DIR points at the real bin/ directory
# even when invoked via /usr/local/bin/<symlink>.
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  link_dir="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$link_dir/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
source "$SCRIPT_DIR/lib/session-cleanup.sh"

die() { echo "Error: $1" >&2; exit 1; }

# Check Docker daemon is running
docker info >/dev/null 2>&1 \
  || die "Docker is not running."

# Check container exists and is running
STATUS=$(docker inspect --format '{{.State.Status}}' "$CONTAINER" 2>/dev/null) \
  || die "Container '$CONTAINER' does not exist. Run: vibe-docker-ctrl start"
[[ "$STATUS" == "running" ]] \
  || die "Container '$CONTAINER' is $STATUS. Run: vibe-docker-ctrl start"

# Check current directory is mounted in the container
MOUNTS=$(docker inspect --format '{{range .Mounts}}{{.Source}} {{end}}' "$CONTAINER")
MOUNTED=false
for src in $MOUNTS; do
  [[ "$WORKDIR" == "$src" || "$WORKDIR" == "$src/"* ]] && MOUNTED=true && break
done
$MOUNTED || die "Directory '$WORKDIR' is not mounted in container.
Add it to config/docker-compose.local.yml volumes."

DOCKER_FLAGS=(-i)
if [[ -t 0 && -t 1 ]]; then
  DOCKER_FLAGS=(-it)
fi

SESSION_ID="$$-$RANDOM-$(date +%s)"
start_session_watchdog "$CONTAINER" "$SESSION_ID" "$$"

docker exec "${DOCKER_FLAGS[@]}" \
  -e "VIBE_SESSION_ID=$SESSION_ID" \
  -u "$DOCKER_USER" -w "$WORKDIR" "$CONTAINER" \
  vibe-session --yolo "$@"
EXIT_CODE=$?

run_session_cleanup "$CONTAINER" "$SESSION_ID"

exit $EXIT_CODE
