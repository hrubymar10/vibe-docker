# All variables are auto-detected by vibe-docker-ctrl.
# Only set these if you need to override the defaults.

# HOST_USER=                    # default: $(whoami)
# HOST_UID=                     # default: $(id -u)
# HOST_HOME=                    # default: $HOME (e.g. /Users/you on macOS, /home/you on Linux)
# VIBE_HOME=                    # default: $HOME/.vibe
# MISTRAL_API_KEY=              # optional: Mistral API key passed through to vibe
# GITHUB_TOKEN=                 # default: $(gh auth token)
# GITLAB_TOKEN=                 # default: $(glab config get token --host gitlab.com)
                                 #   Only needed for the `glab` CLI (GitLab API). Git over SSH
                                 #   works via SSH agent forwarding without any token.
                                 #   To populate it on the host run once:
                                 #     glab auth login --hostname gitlab.com --web
                                 #   (or set a Personal Access Token with the `api` scope here).
# GITLAB_HOST=                  # default: gitlab.com — set only for self-managed GitLab
# GIT_USER_NAME=                # default: $(git config user.name)
# GIT_USER_EMAIL=               # default: $(git config user.email)
# GIT_PROTECTED_BRANCHES=main master
# GIT_AUTH_USER=                # optional: username for non-GitHub git remotes
# GIT_AUTH_TOKEN=               # optional: token/password for non-GitHub git remotes
                                 #   (both required together; enables a generic git
                                 #   credential helper inside the container)
# GOPRIVATE=
# GONOSUMDB=                    # default: same as GOPRIVATE
# CONTAINER_SHELL=              # default: auto-detected from host $SHELL
                                  # Available: bash, zsh, fish, dash, elvish, ksh,
                                  #   mksh, nu, oksh, tcsh, yash (short names or full paths)
# SSH agent forwarding is auto-detected from SSH_AUTH_SOCK — no config needed.

# ── Container resource limits ──────────────────────────────────
# DOCKER_MEMORY_LIMIT=8g        # Memory limit (e.g. 4g, 8g, 16g). 0 = unlimited (default)

# ── GPU passthrough (requires NVIDIA Container Toolkit) ────────
# DOCKER_GPU=                   # "all" for all GPUs, or specific IDs like "0" or "0,1"
                                 # Linux only — requires NVIDIA Container Toolkit.
                                 # Not available on macOS (no NVIDIA driver support).

# ── Build customization ───────────────────────────────────────
# EXTRA_PACKAGES=               # Additional Alpine packages to install (space-separated)
                                 # e.g. EXTRA_PACKAGES=imagemagick ffmpeg sqlite
# EXTRA_GO_PACKAGES=            # Additional Go tools to install via `go install` (space-separated)
                                 # e.g. EXTRA_GO_PACKAGES="github.com/hrubymar10/aimebu/cmd/aimebu@v0.0.0"
                                 # Use a pinned tag for reproducible builds; @latest or @master allowed for dev use.
                                 # Only public Go modules are supported (GOPRIVATE is not plumbed into the build).
# EXTRA_NPM_PACKAGES=           # Additional npm packages to install globally (space-separated)
                                 # e.g. EXTRA_NPM_PACKAGES="puppeteer-core"
# VIBE_VERSION=         # Pin mistral-vibe to a specific Python package version
                                 # Leave empty for latest (default)

# AWS credential proxy — consume an independently running aws-ai-proxy service.
# Project: https://github.com/hrubymar10/aws-ai-proxy
# The control script fetches enabled profiles from $AWS_AI_PROXY_URL/profiles.
# AWS_AI_PROXY_ENABLED=false
# AWS_AI_PROXY_URL=http://host.docker.internal:9998

# ── Notifications ───────────────────────────────────────────────
# config/vibe-notifier            # Optional script mounted into the container as
                                 # /usr/local/bin/vibe-notifier. A compatibility
                                 # symlink also exposes it as claude-notifier.
